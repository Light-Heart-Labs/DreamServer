    },
    "Vikunja: search by issue URL":  { "main": [[{ "node": "Pick matching task",         "type": "main", "index": 0 }]] },
    "Pick matching task":            { "main": [[{ "node": "Found task?",                "type": "main", "index": 0 }]] },
    "Found task?": {
      "main": [
